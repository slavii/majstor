APP_NAME=Majstor
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=bg
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=bg_BG

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=13306
DB_DATABASE=majstor
DB_USERNAME=majstor
DB_PASSWORD=majstor_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# OpenAI (optional — AI assistant uses a fake fallback without this)
OPENAI_API_KEY=

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
